# ============================================
# MoYu FlowSub 环境变量配置文件（模板）
# 复制本文件为 .env 后按需填写，不要提交真实密钥到仓库
# ============================================

# ===== 七牛云 Kodo 对象存储配置 =====
# 用于会话归档：字幕、音频、总结等资源上传到七牛云
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_DOMAIN=
# Kodo 归档对象前缀，默认 moyu-flowsub
QINIU_ARCHIVE_PREFIX=moyu-flowsub
# 是否为私有空间，true 时下载链接需要签名
QINIU_PRIVATE_BUCKET=false
# 私有资源下载链接有效期，单位秒
QINIU_DOWNLOAD_EXPIRE_SECONDS=3600

# ===== Qwen / DashScope 配置（ASR + 翻译 + 总结）=====
# 开启后 ASR 不可用时使用 Qwen ASR，翻译和总结使用 Qwen Chat API
QWEN_ENABLED=true
# DashScope API Key，从阿里云百炼控制台获取
DASHSCOPE_API_KEY=
# Qwen ASR 模型（实时语音识别）
QWEN_ASR_MODEL=qwen3-asr-flash-realtime
# Qwen 翻译模型（OpenAI 兼容 Chat API）
QWEN_TRANSLATION_MODEL=qwen-plus
# Qwen 总结模型
QWEN_SUMMARY_MODEL=qwen-plus
# DashScope OpenAI 兼容接口地址
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 单次 API 调用超时时间，单位毫秒
QWEN_TIMEOUT_MS=12000
# 翻译温度，0 表示确定性输出
QWEN_TEMPERATURE=0

# ===== ASR 降级策略 =====
# Mock ASR 保底（阿里云 NLS 和 Qwen ASR 都不可用时自动启用）
ASR_MOCK_ENABLED=true

# ===== 音频切片 =====
# 后端每次处理音频的间隔，单位毫秒
AUDIO_CHUNK_DURATION_MS=200

# ===== 前端配置 =====
# 前端 WebSocket 连接地址覆盖项，留空则自动使用当前页面地址
VITE_WS_BASE_URL=
# 前端 AudioWorklet 每次切片的间隔，单位毫秒
VITE_AUDIO_CHUNK_DURATION_MS=200

