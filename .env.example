# ============================================
# MoYu FlowSub 环境变量配置文件（模板）
# 复制本文件为 .env 后按需填写，不要提交真实密钥到仓库
# ============================================

# ===== 七牛云 Kodo 对象存储配置 =====
# 用于后续阶段归档音频、字幕和会话文件
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_DOMAIN=
# Kodo 归档对象前缀，默认 moyu-flowsub
QINIU_ARCHIVE_PREFIX=moyu-flowsub
# 是否为私有空间，true 时下载链接需要签名
QINIU_PRIVATE_BUCKET=false
# 私有资源下载链接有效期，单位秒
QINIU_DOWNLOAD_EXPIRE_SECONDS=3600

# ===== 七牛云智能语音识别配置（优先级最高）=====
# 开启后优先使用七牛云实时 ASR，未配置或不开启则降级到 FunASR 或 Mock
QINIU_ASR_ENABLED=true
# 注意：这是七牛云 AI Token API Key，不是 Kodo 的 AccessKey
QINIU_AI_API_KEY=
# 七牛云智能语音 WebSocket 地址
QINIU_ASR_WS_URL=wss://api.qnaigc.com/v1/voice/asr

# ===== DeepSeek 翻译与会后总结配置 =====
# 开启后 ASR 稳定字幕会自动生成中文译文，会话归档时也会生成 AI 摘要、时间线、术语表和重点句
# 未配置则降级到 Mock 翻译和 Mock 总结
DEEPSEEK_ENABLED=false
DEEPSEEK_API_KEY=
# OpenAI 兼容接口地址
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash
# 单次翻译调用超时时间，单位毫秒
DEEPSEEK_TIMEOUT_MS=12000
# 翻译温度，0 表示确定性输出，延迟更低
DEEPSEEK_TEMPERATURE=0

# ===== ASR 降级策略 =====
# Mock ASR 保底（七牛云和 FunASR 都不可用时自动启用）
ASR_MOCK_ENABLED=true

# FunASR 本地 WebSocket 服务（七牛云不可用时的第一降级方案）
# 需要先在本地启动 FunASR 服务，再开启此项
FUNASR_ENABLED=false
# 兼容旧配置，废弃中，建议用下方的 FUNASR_WS_ENDPOINT
FUNASR_ENDPOINT=
# FunASR 本地 WebSocket 地址，例如 ws://localhost:10095
FUNASR_WS_ENDPOINT=

# ===== 音频切片 =====
# 后端每次处理音频的间隔，单位毫秒
AUDIO_CHUNK_DURATION_MS=200

# ===== 前端配置 =====
# 前端 WebSocket 连接地址覆盖项，留空则自动使用当前页面地址
VITE_WS_BASE_URL=
# 前端 AudioWorklet 每次切片的间隔，单位毫秒
VITE_AUDIO_CHUNK_DURATION_MS=200

# ===== 第七阶段：Miku 快直播与 FFmpeg 拉流 =====
# 开启后后端会生成 Miku 推流/播放地址，并尝试用 FFmpeg 拉取直播音频送入 ASR
MIKU_ENABLED=false
MIKU_API_HOST=https://mls.cn-east-1.qiniumiku.com
MIKU_REGION=cn-east-1
MIKU_PUBLISH_DOMAIN=
MIKU_PLAY_DOMAIN=
MIKU_WHEP_DOMAIN=
MIKU_STREAM_PREFIX=moyu-flowsub

# FFmpeg 外部二进制路径；留空时默认调用 PATH 中的 ffmpeg / ffprobe
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
# Miku 或 FFmpeg 不可用时是否启用 Mock 直播源保底
MEDIA_MOCK_ENABLED=true
